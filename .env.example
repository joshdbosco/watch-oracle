# ─── Notion ──────────────────────────────────────────────────
# Create an internal integration at https://www.notion.so/my-integrations
# Share both databases with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ID of your Watches database in Notion
# (grab from the URL: notion.so/{workspace}/{DATABASE_ID}?v=...)
NOTION_WATCHES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ID of your Quiz Submissions database in Notion
NOTION_SUBMISSIONS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Resend ──────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The address that receives quiz submissions
RESEND_TO_EMAIL=you@yourdomain.com

# The from address (must be a verified domain in Resend)
RESEND_FROM_EMAIL=oracle@yourdomain.com

# ─── Admin panel ─────────────────────────────────────────────
# Run: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"
# Paste the output hash here. Never put the plain password.
ADMIN_PASSWORD_HASH=$2a$10$examplehashexamplehashexamplehashexamplehashexamplehash

# Any long random string — used to sign the admin session cookie
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
